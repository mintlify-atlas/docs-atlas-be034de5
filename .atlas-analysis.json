  "keyFeatures": [
    "Modular part-based architecture for building autonomous vehicles",
    "Multiple vehicle templates (complete, path_follow, cv_control, simulator)",
    "Deep learning autopilot with TensorFlow and PyTorch support",
    "Computer vision and GPS-based navigation",
    "Built-in simulator for virtual testing and racing",
    "Support for diverse hardware: Raspberry Pi, Jetson Nano, various cameras and sensors",
    "Web-based UI for driving and configuration",
    "Data collection and telemetry recording (Tub format)",
    "Model training pipeline with augmentations",
    "Pre-built parts for cameras, controllers, actuators, sensors, and more"
  ],
  "publicApiSurface": [
    "Vehicle - Main vehicle loop class for building autonomous cars",
    "Vehicle.add() - Add parts to the vehicle pipeline",
    "Vehicle.start() - Start the vehicle drive loop",
    "Memory - Shared memory for passing data between parts",
    "donkey createcar - CLI command to create new car application",
    "donkey train - CLI command to train autopilot models",
    "donkey calibrate - CLI command to calibrate servos and motors",
    "KerasPilot - Base class for deep learning autopilots",
    "WebController - Web-based driving interface",
    "CvCam - Camera part for capturing images",
    "PCA9685 - Motor controller for steering and throttle",
    "TubWriter - Data recording part",
    "GPSPath - GPS-based path following",
    "Lidar - Lidar sensor integration"
  ]
}
